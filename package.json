{
  "name": "axon-feature-builder",
  "displayName": "Axon Feature Builder",
  "description": "Browse Jira features and launch the /feature skill in Claude Code.",
  "version": "0.1.0",
  "publisher": "axon",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "axonFeatureBuilder",
          "title": "Axon Features",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "axonFeatureBuilder": [
        {
          "id": "axonFeatureBuilder.activeFeatures",
          "name": "Active Features"
        },
        {
          "id": "axonFeatureBuilder.jira",
          "name": "Jira"
        }
      ]
    },
    "commands": [
      {
        "command": "axonFeatureBuilder.openJiraBrowser",
        "title": "Axon: Open Jira Browser"
      },
      {
        "command": "axonFeatureBuilder.refreshActiveFeatures",
        "title": "Axon: Refresh Active Features",
        "icon": "$(refresh)"
      },
      {
        "command": "axonFeatureBuilder.buildFeature",
        "title": "Axon: Build Feature with Claude"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "axonFeatureBuilder.refreshActiveFeatures",
          "when": "view == axonFeatureBuilder.activeFeatures",
          "group": "navigation"
        },
        {
          "command": "axonFeatureBuilder.openJiraBrowser",
          "when": "view == axonFeatureBuilder.jira",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.js && npm run build:css",
    "build:css": "tailwindcss -i ./webview/styles.css -o ./dist/webview.css --minify",
    "watch": "node esbuild.js --watch & tailwindcss -i ./webview/styles.css -o ./dist/webview.css --watch",
    "package": "npm run build && vsce package",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p webview/tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.19.10",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "lucide-react": "^0.303.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
